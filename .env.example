# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://malaysiapropertynetwork.com

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# International format, no + or spaces (e.g. 60137757058)
NEXT_PUBLIC_WHATSAPP_NUMBER=60137757058

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC_ or import in client components
# Required for admin listings CRUD, image upload, and CRM dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard password (server-only)
ADMIN_PASSWORD=change-me-in-production

# ─── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=123456789012345
