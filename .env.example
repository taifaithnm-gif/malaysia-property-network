# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://malaysiapropertynetwork.com

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# International format, no + or spaces (e.g. 60123456789)
NEXT_PUBLIC_WHATSAPP_NUMBER=60123456789

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC_ or import in client components
# Optional for Phase 5 landing (API routes currently use anon key + RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=123456789012345
